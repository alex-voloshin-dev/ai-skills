.DS_Store
Thumbs.db
*.log
*.tmp
settings.local.json

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# ai-assets plugin memory (seeded by /ai-assets-init)
# Per D9: .ai-assets-memory/ is gitignored by default, with opt-in .committed/ for versioned content.

# Ignore ALL .ai-assets-memory contents...
.ai-assets-memory/*

# ...EXCEPT the .committed/ subdir (opt-in versioned content)
!.ai-assets-memory/.committed/

# Ignore .committed/ contents that don't match the allowlist
# (allowlist enforced by pre-tool-use-committed-write.py hook)
.ai-assets-memory/.committed/*

# Allowlist exceptions: README, conventions, eval baselines, architecture decisions, PII pattern extensions
!.ai-assets-memory/.committed/README.md
!.ai-assets-memory/.committed/conventions.md
!.ai-assets-memory/.committed/architecture-decisions/
!.ai-assets-memory/.committed/architecture-decisions/*.md
!.ai-assets-memory/.committed/eval-baselines/
!.ai-assets-memory/.committed/eval-baselines/*.json
!.ai-assets-memory/.committed/pii-patterns.txt
!.ai-assets-memory/.committed/.allowlist-extensions.txt
!.ai-assets-memory/.committed/decisions/
!.ai-assets-memory/.committed/decisions/*.md
!.ai-assets-memory/.committed/releases/
!.ai-assets-memory/.committed/releases/**/*.md
